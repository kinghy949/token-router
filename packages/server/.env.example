# App
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="mysql://root:password@localhost:3306/token_router"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Upstream (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Billing (per 1K tokens)
INPUT_TOKEN_PRICE=1
OUTPUT_TOKEN_PRICE=5

# Limits
RATE_LIMIT_PER_MINUTE=60
REDEEM_RATE_LIMIT_PER_MINUTE=5
REQUEST_BODY_LIMIT=10mb

# CORS
WEB_URL=http://localhost:8080

# Optional bootstrap admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# Provider routing
PROVIDER_PRIORITY=anthropic,bedrock,vertex
PROXY_MAX_FAILOVER=3
