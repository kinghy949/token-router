# Compose ports
SERVER_PORT=3000
WEB_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379

# Database
MYSQL_DATABASE=token_router
MYSQL_ROOT_PASSWORD=password

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Optional bootstrap admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# Upstream
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
BEDROCK_BASE_URL=
BEDROCK_API_KEY=
VERTEX_BASE_URL=
VERTEX_API_KEY=

# Billing
INPUT_TOKEN_PRICE=1
OUTPUT_TOKEN_PRICE=5

# Limits
RATE_LIMIT_PER_MINUTE=60
REDEEM_RATE_LIMIT_PER_MINUTE=5
REQUEST_BODY_LIMIT=10mb

# CORS
WEB_URL=http://localhost:8080

# Provider routing
PROVIDER_PRIORITY=anthropic,bedrock,vertex
PROXY_MAX_FAILOVER=3
